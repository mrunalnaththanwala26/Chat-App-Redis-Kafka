PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/chat_app
JWT_SECRET=change-me-in-production-use-long-secret
JWT_EXPIRES_IN=7d
REDIS_URL=redis://127.0.0.1:6379
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_MESSAGE_SENT=message_sent
SKIP_KAFKA=false
MAX_FILE_SIZE_BYTES=1073741824
PUBLIC_BASE_URL=http://localhost:3000
UPLOAD_DIR=./uploads
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@chatapp.local
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
